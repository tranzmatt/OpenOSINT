# OpenOSINT — Environment Variables
# Copy this file to .env and fill in your keys
# Never commit .env to git

# AI backend — choose ONE of the following.
#
# 1) Anthropic Claude (default)
ANTHROPIC_API_KEY=sk-ant-...
#
# 2) Any OpenAI-compatible endpoint (LiteLLM, llama-swap, vLLM, LM Studio, …).
#    Set OPENAI_BASE_URL to enable.  Takes precedence over Ollama when no
#    ANTHROPIC_API_KEY is set.  The model's server must support tool/function
#    calling (e.g. llama.cpp launched with --jinja).
# OPENAI_BASE_URL=http://localhost:4000/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Optional — required to let POST /api/setup be called from a non-localhost
# caller (e.g. a public web deployment). Leave unset to keep /api/setup
# localhost-only. If set, remote callers must send it as X-Setup-Token.
# OPENOSINT_SETUP_TOKEN=

# Optional — data breach checks
HIBP_API_KEY=your_key

# Optional — IP intelligence
IPINFO_TOKEN=your_token

# Sponsored — IP2Location Security Plan
IP2LOCATION_API_KEY=your_key

# Optional — VirusTotal
VIRUSTOTAL_API_KEY=your_key

# Optional — Shodan
SHODAN_API_KEY=your_key

# Optional — Censys
CENSYS_API_ID=your_id
CENSYS_SECRET=your_secret

# Optional — AbuseIPDB IP reputation
ABUSEIPDB_API_KEY=your_key

# Optional — GitHub profile/repo/email discovery (raises rate limit 60 → 5000 req/h)
GITHUB_TOKEN=your_token

# Optional — Bright Data (search_dorks_live + scrape_url tools)
# Free tier: 5,000 requests/month — https://get.brightdata.com/984ni58s2oad
# OpenOSINT earns a referral commission if you sign up through this link.
BRIGHTDATA_API_KEY=your_key
BRIGHTDATA_SERP_ZONE=serp_api1
BRIGHTDATA_UNLOCKER_ZONE=web_unlocker1

# ── OpenOSINT Cloud (cloud/ gateway) ─────────────────────────────────────────
# Required for production; omit to run with the in-memory backend (tests only).

# Heroku Postgres — set automatically by: heroku addons:create heroku-postgresql
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Fernet key for encrypting customer BYOK secrets at rest.
# Required when DATABASE_URL is set.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONFIG_ENCRYPTION_KEY=

# Polar.sh credentials — https://polar.sh/dashboard/settings/developers
POLAR_TOKEN=pat_...
# Webhook signing secret — Polar dashboard → Developer → Webhooks → <endpoint> → Secret
POLAR_WEBHOOK_SECRET=whsec_...

# Polar hosted checkout URLs — set after creating products in Polar dashboard
POLAR_CHECKOUT_PAYG=https://polar.sh/your-org/payg/purchase
POLAR_CHECKOUT_STARTER=https://polar.sh/your-org/starter/purchase
POLAR_CHECKOUT_PRO=https://polar.sh/your-org/pro/purchase

# Polar benefit IDs — Polar dashboard → Products → <product> → Benefits → copy ID
# Maps incoming benefit_grant.created events to the correct plan.
POLAR_BENEFIT_ID_PAYG=benefit_...
POLAR_BENEFIT_ID_STARTER=benefit_...
POLAR_BENEFIT_ID_PRO=benefit_...

# Polar product IDs — used to refill credits on subscription renewal
POLAR_PRODUCT_ID_STARTER=prod_...
POLAR_PRODUCT_ID_PRO=prod_...
